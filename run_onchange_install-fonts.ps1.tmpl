{{ if eq .chezmoi.os "windows" -}}
# Install FiraCode Nerd Font per-user (no admin required).
# run_onchange: bump this version to force a re-run on all machines.
# nerd-fonts version: latest
$ErrorActionPreference = "Stop"

$fontsDir = "$env:LOCALAPPDATA\Microsoft\Windows\Fonts"
$regKey = "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\Fonts"

if (Test-Path "$fontsDir\FiraCodeNerdFont-Regular.ttf") {
    Write-Host "FiraCode Nerd Font already installed, skipping."
    exit 0
}

New-Item -ItemType Directory -Force $fontsDir | Out-Null
if (-not (Test-Path $regKey)) { New-Item -Path $regKey -Force | Out-Null }

$zip = Join-Path $env:TEMP "FiraCode-NerdFont.zip"
$extract = Join-Path $env:TEMP "FiraCode-NerdFont"
Write-Host "Downloading FiraCode Nerd Font..."
Invoke-WebRequest "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip" -OutFile $zip
Expand-Archive $zip -DestinationPath $extract -Force

Get-ChildItem $extract -Filter *.ttf | ForEach-Object {
    Copy-Item $_.FullName $fontsDir -Force
    New-ItemProperty -Path $regKey -Name "$($_.BaseName) (TrueType)" `
        -Value (Join-Path $fontsDir $_.Name) -PropertyType String -Force | Out-Null
    Write-Host "Installed $($_.Name)"
}

Remove-Item $zip, $extract -Recurse -Force
Write-Host "FiraCode Nerd Font installed. Restart apps to pick it up."
{{ end -}}
